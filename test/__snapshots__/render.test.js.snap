an></a><div class="row"><div class="col-xs-8 col-xs-offset-2"><img class="skillBorder" src="images/arrow.png"></div></div></div><div class="col-xs-12 passiveMargin"><a class="tooltips"><img class="skillBorder" src="images/skills/Flurry.png"><span style="width:200px; bottom:30px; right:-100px;">Flurry<br />Weapon skill required: 15<br />Damage:87(Strength based).</span></a><div class="row"><div class="col-xs-8 col-xs-offset-2"><img class="skillBorder" src="images/arrow.png"></div></div></div><div class="col-xs-12 passiveMargin"><a class="tooltips"><img class="skillBorder" src="images/skills/Frenzy.png"><span style="width:200px; bottom:30px; right:-100px;">Frenzy<br />Weapon skill required: 20<br />Damage:119(Strength based).</span></a><div class="row"><div class="col-xs-8 col-xs-offset-2"><img class="skillBorder" src="images/arrow.png"></div></div></div></div></div><div class="col-xs-2"><div class="row"><div class="col-xs-12 passiveMargin"><a class="tooltips"><img class="skillBorder" src="images/skills/HammerTime.png"><span style="width:200px; bottom:30px; right:-100px;">Hammer Time<br />Weapon skill required: 1<br />Damage:22(Strength based).</span></a><div class="row"><div class="col-xs-8 col-xs-offset-2"><img class="skillBorder" src="images/arrow.png"></div></div></div><div class="col-xs-12 passiveMargin"><a class="tooltips"><img class="skillBorder" src="images/skills/DominatingSlam.png"><span style="width:200px; bottom:30px; right:-100px;">Dominating Slam<br />Weapon skill required: 5<br />Damage:35(Wisdom + Endurance based).</span></a><div class="row"><div class="col-xs-8 col-xs-offset-2"><img class="skillBorder" src="images/arrow.png"></div></div></div><div class="col-xs-12 passiveMargin"><a class="tooltips"><img class="skillBorder" src="images/skills/Gash.png"><span style="width:200px; bottom:30px; right:-100px;">Gash<br />Weapon skill required: 10<br />Damage:64(Wisdom + Endurance based).</span></a><div class="row"><div class="col-xs-8 col-xs-offset-2"><img class="skillBorder" src="images/arrow.png"></div></div></div><div class="col-xs-12 passiveMargin"><a class="tooltips"><img class="skillBorder" src="images/skills/OverBearingWallop.png"><span style="width:200px; bottom:30px; right:-100px;">Overbearing Wallop<br />Weapon skill required: 15<br />Damage:96(Wisdom based).</span></a><div class="row"><div class="col-xs-8 col-xs-offset-2"><img class="skillBorder" src="images/arrow.png"></div></div></div><div class="col-xs-12 passiveMargin"><a class="tooltips"><img class="skillBorder" src="images/skills/Tremor.png"><span style="width:200px; bottom:30px; right:-100px;">Tremor<br />Weapon skill required: 20<br />Damage:143(Endurance + Wisdom based).</span></a><div class="row"><div class="col-xs-8 col-xs-offset-2"><img class="skillBorder" src="images/arrow.png"></div></div></div></div></div><div class="col-xs-2"><div class="row"><div class="col-xs-12 passiveMargin"><a class="tooltips"><img class="skillBorder" src="images/skills/Starlight.png"><span style="width:200px; bottom:30px; right:-100px;">Starlight<br />Weapon skill required: 1<br />Damage:48(Intelligence + Wisdom based).</span></a><div class="row"><div class="col-xs-8 col-xs-offset-2"><img class="skillBorder" src="images/arrow.png"></div></div></div><div class="col-xs-12 passiveMargin"><a class="tooltips"><img class="skillBorder" src="images/skills/Intone.png"><span style="width:200px; bottom:30px; right:-100px;">Intone<br />Weapon skill required: 5<br />You have a chance(21) to empower one of your spells dealing bonus damage(12).<br/>It work's for each active spell in battle.</span></a><div class="row"><div class="col-xs-8 col-xs-offset-2"><img class="skillBorder" src="images/arrow.png"></div></div></div><div class="col-xs-12 passiveMargin"><a class="tooltips"><img class="skillBorder" src="images/skills/HateCannon.png"><span style="width:200px; bottom:30px; right:-100px;">Hate Cannon<br />Weapon skill required: 10<br />Damage:72(Intelligence based).</span></a><div class="row"><div class="col-xs-8 col-xs-offset-2"><img class="skillBorder" src="images/arrow.png"></div></div></div><div class="col-xs-12 passiveMargin"><a class="tooltips"><img class="skillBorder" src="images/skills/BeguilersOrb.png"><span style="width:200px; bottom:30px; right:-100px;">Beguiler's Orb<br />Weapon skill required: 15<br />Damage:127(Intelligence + Wisdom based).</span></a><div class="row"><div class="col-xs-8 col-xs-offset-2"><img class="skillBorder" src="images/arrow.png"></div></div></div><div class="col-xs-12 passiveMargin"><a class="tooltips"><img class="skillBorder" src="images/skills/SpellSimulacrum.png"><span style="width:200px; bottom:30px; right:-100px;">Spell Simulacrum<br />Weapon skill required: 20<br />Increase your total spell power(2%)</span></a><div class="row"><div class="col-xs-8 col-xs-offset-2"><img class="skillBorder" src="images/arrow.png"></div></div></div></div></div><div class="col-xs-2"><div class="row"><div class="col-xs-12 passiveMargin"><a class="tooltips"><img class="skillBorder" src="images/skills/PierceTheVeil.png"><span style="width:200px; bottom:30px; right:-100px;">Pierce the Veil<br />Weapon skill required: 1<br />Damage:40(Dexterity based).</span></a><div class="row"><div class="col-xs-8 col-xs-offset-2"><img class="skillBorder" src="images/arrow.png"></div></div></div><div class="col-xs-12 passiveMargin"><a class="tooltips"><img class="skillBorder" src="images/skills/SkyCracker.png"><span style="width:200px; bottom:30px; right:-100px;">Sky Cracker<br />Weapon skill required: 5<br />Damage:62(Dexterity based).</span></a><div class="row"><div class="col-xs-8 col-xs-offset-2"><img class="skillBorder" src="images/arrow.png"></div></div></div><div class="col-xs-12 passiveMargin"><a class="tooltips"><img class="skillBorder" src="images/skills/ArcherFocus.png"><span style="width:200px; bottom:30px; right:-100px;">Archer Focus<br />Weapon skill required: 10<br />Critical Chance: 0% (Can increase it over 50% cap).</span></a><div class="row"><div class="col-xs-8 col-xs-offset-2"><img class="skillBorder" src="images/arrow.png"></div></div></div><div class="col-xs-12 passiveMargin"><a class="tooltips"><img class="skillBorder" src="images/skills/MakeItRain.png"><span style="width:200px; bottom:30px; right:-100px;">Make it Rain<br />Weapon skill required: 15<br />Damage:84(Dexterity + Strength based).</span></a><div class="row"><div class="col-xs-8 col-xs-offset-2"><img class="skillBorder" src="images/arrow.png"></div></div></div><div class="col-xs-12 passiveMargin"><a class="tooltips"><img class="skillBorder" src="images/skills/RangersRevenge.png"><span style="width:200px; bottom:30px; right:-100px;">Ranger's Revenge<br />Weapon skill required: 20<br />Damage:106(Dexterity + Strength based).</span></a><div class="row"><div class="col-xs-8 col-xs-offset-2"><img class="skillBorder" src="images/arrow.png"></div></div></div></div></div></div></div></div>"`;

exports[`render snapshots (fixed game state) > EquippedItemsEmpty 1`] = `"<div class="row" style="padding-top: 5px; padding-bottom: 10px;"><div class="centerText"><h4>Equipped Items</h4></div><div class="col-xs-10 col-xs-offset-1"><div class="row"><div class="col-xs-4 marginTest"id="talismanEmpty"><img src=images/talismanEmpty.png></div><div class="col-xs-4 marginTest"id="helmetEmpty"><img src=images/helmetEmpty.png></div><div class="col-xs-4 marginTest"id="amuletEmpty"><img src=images/amuletEmpty.png></div></div></div><div class="col-xs-10 col-xs-offset-1"><div class="row"><div class="col-xs-4 marginTest"id="weaponEmpty"><img src=images/weaponEmpty.png></div><div class="col-xs-4 marginTest"id="chestEmpty"><img src=images/chestEmpty.png></div><div class="col-xs-4 marginTest"id="shieldEmpty"><img src=images/shieldEmpty.png></div></div></div><div class="col-xs-10 col-xs-offset-1"><div class="row"><div class="col-xs-4 marginTest"></div><div class="col-xs-4 marginTest"id="legsEmpty"><img src=images/legsEmpty.png></div><div class="col-xs-4 marginTest"id="ringEmpty"><img src=images/ringEmpty.png></div></div></div><div class="col-xs-10 col-xs-offset-1"><div class="row"><div class="col-xs-4 col-xs-offset-4"id="bootsEmpty"><img src=images/bootsEmpty.png></div></div></div></div>"`;

exports[`render snapshots (fixed game state) > characterCreationHtml (race grid, empty heroRace) 1`] = `"<div class="row"><div class="col-xs-12 col-xs-offset-1"><div class="row"><div class="col-xs-6 col-xs-offset-2"><img src="images/races/AdulthoodHuman.png">Human <a class="tooltips"><p class="glyphicon glyphicon-info-sign" style="color:black"></p><span style="width:350px; left: 110px; bottom:-30px; text-align:left;"><div class="row"><div class="col-xs-10 col-xs-offset-1">Human</div></div><div class="row"><div class="col-xs-5" style="padding-left:46px;">Str: <font color="red">+</font><br />End: <font color="red">+</font><br />Agi: <font color="green">+</font><font color="green">+</font><font color="green">+</font><font color="green">+</font><font color="green">+</font><br />Dex: <font color="green">+</font><font color="green">+</font><font color="green">+</font><font color="green">+</font><font color="green">+</font><br />Wis: <font color="red">+</font><font color="red">+</font><br />Int: <font color="red">+</font><font color="red">+</font><br />Luc: <font color="green">+</font><font color="green">+</font><font color="green">+</font><font color="green">+</font><font color="green">+</font><br /></div><div class="col-xs-7">Bonuses:<br />All Stats: +20%<br />Exp Rate: +50%<br />Drop Rate: +50%<br />Gold Drop: +50%<br /><br /><img src="images/races/AdulthoodHuman.png"></div></div><div class="row"><div class="col-xs-10 col-xs-offset-1"><br /><font color="#CC6633">"Humans possess exceptional drive and a great capacity to endure and expand, and as such are currently the dominant race in the world."</font></div></div></span></a></div><div class="col-xs-2"><button type="button" style="margin-bottom:5px;" class="btn btn-default border" class="Human" onclick="changeRace('Human', 'human');">Choose</button></div><div class="col-xs-6 col-xs-offset-2"><img src="images/races/AdulthoodHalfElf.png">Half Elf <a class="tooltips"><p class="glyphicon glyphicon-info-sign" style="color:black"></p><span style="width:350px; left: 110px; bottom:-30px; text-align:left;"><div class="row"><div class="col-xs-10 col-xs-offset-1">Half Elf</div></div><div class="row"><div class="col-xs-5" style="padding-left:46px;">Str: <font color="red">+</font><font color="red">+</font><br />End: <font color="red">+</font><font color="red">+</font><br />Agi: <font color="green">+</font><font color="green">+</font><font color="green">+</font><font color="green">+</font><br />Dex: <font color="green">+</font><font color="green">+</font><font color="green">+</font><font color="green">+</font><br />Wis: <font color="green">+</font><font color="green">+</font><font color="green">+</font><font color="green">+</font><br />Int: <font color="green">+</font><font color="green">+</font><font color="green">+</font><font color="green">+</font><br />Luc: <font color="red">+</font><br /></div><div class="col-xs-7">Bonuses:<br />All Stats: +10%<br />Gold Drop: +30%<br />Drop Rate: +30%<br />Exp Rate: +30%<br />Evasion: +5%<br /><br /><img src="images/races/AdulthoodHalfElf.png"></div></div><div class="row"><div class="col-xs-10 col-xs-offset-1"><br /><font color="#CC6633">"Elves have long drawn the covetous gazes of other races. Their generous lifespans, magical affinity, and inherent grace each contribute to the admiration or bitter envy of their neighbors."</font></div></div></span></a></div><div class="col-xs-2"><button type="button" style="margin-bottom:5px;" class="btn btn-default border" class="Half Elf" onclick="changeRace('Half Elf', 'halfElf');">Choose</button></div><div class="col-xs-6 col-xs-offset-2"><img src="images/races/AdulthoodDwarf.png">Dwarf <a class="tooltips"><p class="glyphicon glyphicon-info-sign" style="color:black"></p><span style="width:350px; left: 110px; bottom:-30px; text-align:left;"><div class="row"><div class="col-xs-10 col-xs-offset-1">Dwarf</div></div><div class="row"><div class="col-xs-5" style="padding-left:46px;">Str: <font color="red">+</font><font color="red">+</font><br />End: <font color="blue">+</font><font color="blue">+</font><font color="blue">+</font><br />Agi: <font color="green">+</font><font color="green">+</font><font color="green">+</font><font color="green">+</font><font color="green">+</font><br />Dex: <font color="blue">+</font><font color="blue">+</font><font color="blue">+</font><br />Wis: <font color="red">+</font><font color="red">+</font><br />Int: <font color="red">+</font><br />Luc: <font color="green">+</font><font color="green">+</font><font color="green">+</font><font color="green">+</font><font color="green">+</font><br /></div><div class="col-xs-7">Bonuses:<br />Evasion: +5%<br />Defense: +20%<br />Gold Drop: +100%<br />Drop Rate: +50%<br /><br /><img src="images/races/AdulthoodDwarf.png"></div></div><div class="row"><div class="col-xs-10 col-xs-offset-1"><br /><font color="#CC6633">"Dwarves are a stoic but stern race, ensconced in cities carved from the hearts of mountains and fiercely determined to repel the depredations of savage races like orcs and goblins."</font></div></div></span></a></div><div class="col-xs-2"><button type="button" style="margin-bottom:5px;" class="btn btn-default border" class="Dwarf" onclick="changeRace('Dwarf', 'dwarf');">Choose</button></div><div class="col-xs-6 col-xs-offset-2"><img src="images/races/AdulthoodOrc.png">Orc <a class="tooltips"><p class="glyphicon glyphicon-info-sign" style="color:black"></p><span style="width:350px; left: 110px; bottom:-30px; text-align:left;"><div class="row"><div class="col-xs-10 col-xs-offset-1">Orc</div></div><div class="row"><div class="col-xs-5" style="padding-left:46px;">Str: <font color="green">+</font><font color="green">+</font><font color="green">+</font><font color="green">+</font><br />End: <font color="green">+</font><font color="green">+</font><font color="green">+</font><font color="green">+</font><br />Agi: <font color="green">+</font><font color="green">+</font><font color="green">+</font><font color="green">+</font><font color="green">+</font><br />Dex: <font color="green">+</font><font color="green">+</font><font color="green">+</font><font color="green">+</font><font color="green">+</font><br />Wis: <font color="red">+</font><br />Int: <font color="red">+</font><br />Luc: <font color="blue">+</font><font color="blue">+</font><font color="blue">+</font><br /></div><div class="col-xs-7">Bonuses:<br />Damage: +20%<br />Health: +10%<br /><br /><img src="images/races/AdulthoodOrc.png"></div></div><div class="row"><div class="col-xs-10 col-xs-offset-1"><br /><font color="#CC6633">"Orcs are aggressive, callous, and domineering. Bullies by nature, they respect strength and power as the highest virtues. On an almost instinctive level, orcs believe they are entitled to anything they want unless someone stronger can stop them from seizing it."</font></div></div></span></a></div><div class="col-xs-2"><button type="button" style="margin-bottom:5px;" class="btn btn-default border" class="Orc" onclick="changeRace('Orc', 'orc');">Choose</button></div><div class="col-xs-6 col-xs-offset-2"><img src="images/races/AdulthoodElf.png">Elf <a class="tooltips"><p class="glyphicon glyphicon-info-sign" style="color:black"></p><span style="width:350px; left: 110px; bottom:-30px; text-align:left;"><div class="row"><div class="col-xs-10 col-xs-offset-1">Elf</div></div><div class="row"><div class="col-xs-5" style="padding-left:46px;">Str: <font color="blue">+</font><font color="blue">+</font><font color="blue">+</font><br />End: <font color="blue">+</font><font color="blue">+</font><font color="blue">+</font><br />Agi: <font color="green">+</font><font color="green">+</font><font color="green">+</font><font color="green">+</font><br />Dex: <font color="green">+</font><font color="green">+</font><font color="green">+</font><font color="green">+</font><br />Wis: <font color="red">+</font><br />Int: <font color="blue">+</font><font color="blue">+</font><font color="blue">+</font><br />Luc: <font color="blue">+</font><font color="blue">+</font><font color="blue">+</font><br /></div><div class="col-xs-7">Bonuses:<br />Never Miss<br />Critical Chance: +5%<br />Evasion: +5%<br />Health: -10%<br /><br /><img src="images/races/AdulthoodElf.png"></div></div><div class="row"><div class="col-xs-10 col-xs-offset-1"><br /><font color="#CC6633">"The long-lived elves are children of the natural world, similar in many superficial ways to fey creatures, though with key differences."</font></div></div></span></a></div><div class="col-xs-2"><button type="button" style="margin-bottom:5px;" class="btn btn-default border" class="Elf" onclick="changeRace('Elf', 'elf');">Choose</button></div><div class="col-xs-6 col-xs-offset-2"><img src="images/races/AdulthoodHalfing.png">Halfing <a class="tooltips"><p class="glyphicon glyphicon-info-sign" style="color:black"></p><span style="width:350px; left: 110px; bottom:-30px; text-align:left;"><div class="row"><div class="col-xs-10 col-xs-offset-1">Halfing</div></div><div class="row"><div class="col-xs-5" style="padding-left:46px;">Str: <font color="red">+</font><br />End: <font color="red">+</font><br />Agi: <font color="orange">+</font><font color="orange">+</font><font color="orange">+</font><font color="orange">+</font><font color="orange">+</font><font color="orange">+</font><br />Dex: <font color="orange">+</font><font color="orange">+</font><font color="orange">+</font><font color="orange">+</font><font color="orange">+</font><font color="orange">+</font><br />Wis: <font color="red">+</font><font color="red">+</font><br />Int: <font color="red">+</font><br />Luc: <font color="green">+</font><font color="green">+</font><font color="green">+</font><font color="green">+</font><br /></div><div class="col-xs-7">Bonuses:<br />Evasion: +10%<br />Damage: -10%<br />Health: -20%<br />Critical Chance: +5%<br /><br /><img src="images/races/AdulthoodHalfing.png"></div></div><div class="row"><div class="col-xs-10 col-xs-offset-1"><br /><font color="#CC6633">"Optimistic and cheerful by nature, blessed with uncanny luck, and driven by a powerful wanderlust, halflings make up for their short stature with an abundance of bravado and curiosity."</font></div></div></span></a></div><div class="col-xs-2"><button type="button" style="margin-bottom:5px;" class="btn btn-default border" class="Halfing" onclick="changeRace('Halfing', 'halfing');">Choose</button></div><div class="col-xs-6 col-xs-offset-2"><img src="images/races/AdulthoodSylph.png">Sylph <a class="tooltips"><p class="glyphicon glyphicon-info-sign" style="color:black"></p><span style="width:350px; left: 110px; bottom:-30px; text-align:left;"><div class="row"><div class="col-xs-10 col-xs-offset-1">Sylph</div></div><div class="row"><div class="col-xs-5" style="padding-left:46px;">Str: <font color="red">+</font><br />End: <font color="red">+</font><br />Agi: <font color="green">+</font><font color="green">+</font><font color="green">+</font><font color="green">+</font><br />Dex: <font color="orange">+</font><font color="orange">+</font><font color="orange">+</font><font color="orange">+</font><font color="orange">+</font><font color="orange">+</font><br />Wis: <font color="red">+</font><br />Int: <font color="green">+</font><font color="green">+</font><font color="green">+</font><font color="green">+</font><font color="green">+</font><br />Luc: <font color="blue">+</font><font color="blue">+</font><font color="blue">+</font><br /></div><div class="col-xs-7">Bonuses:<br />Mana Regen: +100%<br />Max Mana: +50%<br />All Stats: +15%<br />Spell Power: +20%<br /><br /><img src="images/races/AdulthoodSylph.png"></div></div><div class="row"><div class="col-xs-10 col-xs-offset-1"><br /><font color="#CC6633">"Born from the descendants of humans and beings of elemental air such as djinn, sylphs are a shy and reclusive race consumed by intense curiosity."</font></div></div></span></a></div><div class="col-xs-2"><button type="button" style="margin-bottom:5px;" class="btn btn-default border" class="Sylph" onclick="changeRace('Sylph', 'sylph');">Choose</button></div><div class="col-xs-6 col-xs-offset-2"><img src="images/races/AdulthoodGiant.png">Giant <a class="tooltips"><p class="glyphicon glyphicon-info-sign" style="color:black"></p><span style="width:350px; left: 110px; bottom:-30px; text-align:left;"><div class="row"><div class="col-xs-10 col-xs-offset-1">Giant</div></div><div class="row"><div class="col-xs-5" style="padding-left:46px;">Str: <font color="green">+</font><font color="green">+</font><font color="green">+</font><font color="green">+</font><font color="green">+</font><br />End: <font color="blue">+</font><font color="blue">+</font><font color="blue">+</font><br />Agi: <font color="red">+</font><font color="red">+</font><br />Dex: <font color="red">+</font><font color="red">+</font><br />Wis: <font color="green">+</font><font color="green">+</font><font color="green">+</font><font color="green">+</font><font color="green">+</font><br />Int: <font color="red">+</font><br />Luc: <font color="blue">+</font><font color="blue">+</font><font color="blue">+</font><br /></div><div class="col-xs-7">Bonuses:<br />Damage: +40%<br />Health: +30%<br />Max Mana: -50%<br />Accuracy: -25%<br /><br /><img src="images/races/AdulthoodGiant.png"></div></div><div class="row"><div class="col-xs-10 col-xs-offset-1"><br /><font color="#CC6633">"Their great size and strength lends them arguable advantages on the battlefield where they tower over their enemies. Dimwitted and slow moving, giants have use for neither speed nor intelligence, using brawn over brain to overcome obstacles."</font></div></div></span></a></div><div class="col-xs-2"><button type="button" style="margin-bottom:5px;" class="btn btn-default border" class="Giant" onclick="changeRace('Giant', 'giant');">Choose</button></div><div class="row"><div class="col-xs-2 col-xs-offset-5"><button type="button" class="btn btn-default border startBackButtonMargin" onclick="newGameSlot()">Go Back</button></div></div></div></div></div>"`;

exports[`render snapshots (fixed game state) > checkBoxHtml 1`] = `"<div class="row"><div class="col-xs-10 col-xs-offset-1"><div class="centerText"><br /><label><input style="visibility:visible; position:relative;" type="checkbox" id="common" onclick="handleClick();"checked><span style="background-color:gray; width:10px;height:10px;" data-toggle="tooltip" data-placement="top" title="Common">__</span></label><label><input style="visibility:visible; position:relative;" type="checkbox" id="uncommon" onclick="handleClick();"checked><span style="background-color:green; width:10px;height:10px;" data-toggle="tooltip" data-placement="top" title="Uncommon">__</span></label><label><input style="visibility:visible; position:relative;" type="checkbox" id="rare" onclick="handleClick();"><span style="background-color:blue; width:10px;height:10px;" data-toggle="tooltip" data-placement="top" title="Rare">__</span></label><label><input style="visibility:visible; position:relative;" type="checkbox" id="epic" onclick="handleClick();"><span style="background-color:orange; width:10px;height:10px;" data-toggle="tooltip" data-placement="top" title="Epic">__</span></label><label><input style="visibility:visible; position:relative;" type="checkbox" id="legendary" onclick="handleClick();"><span style="background-color:red; width:10px;height:10px;" data-toggle="tooltip" data-placement="top" title="Legendary">__</span></label><br /></div><div class="centerText"><strong>Sell all items by selected rarity(All tabs)</strong><br /><button type="button" class="sell" onclick=sellAllItems();>Sell all</button></div></div></div>"`;

exports[`render snapshots (fixed game state) > checkHeroRace (Human selected) 1`] = `"<a href="#" class="tooltipA"><img src="images/races/AdulthoodHuman.png"><span style="width:350px; right: 10%; top:10px; text-align:left;"><div class="row"><div class="col-xs-10 col-xs-offset-1">Human</div></div><div class="row"><div class="col-xs-5" style="padding-left:46px;">Str: <font color="red">+</font><br />End: <font color="red">+</font><br />Agi: <font color="green">+</font><font color="green">+</font><font color="green">+</font><font color="green">+</font><font color="green">+</font><br />Dex: <font color="green">+</font><font color="green">+</font><font color="green">+</font><font color="green">+</font><font color="green">+</font><br />Wis: <font color="red">+</font><font color="red">+</font><br />Int: <font color="red">+</font><font color="red">+</font><br />Luc: <font color="green">+</font><font color="green">+</font><font color="green">+</font><font color="green">+</font><font color="green">+</font><br /></div><div class="col-xs-7">Bonuses:<br />All Stats: +20%<br />Exp Rate: +50%<br />Drop Rate: +50%<br />Gold Drop: +50%<br /><br /><img src="images/races/AdulthoodHuman.png"></div></div><div class="row"><div class="col-xs-10 col-xs-offset-1"><br /><font color="#CC6633">"Humans possess exceptional drive and a great capacity to endure and expand, and as such are currently the dominant race in the world."</font></div></div></span></a>"`;

exports[`render snapshots (fixed game state) > itemTooltipTest (fixed weapon + shield) 1`] = `"<font color="#4169E1"><strong>Test Sword</strong></font><br /><div class="borderBottom borderTop">Weapon class: Sword<br /><strong><font color="#2175D9">Damage: 10 to 20</font></strong></div>Average Damage: 15<div class="borderBottom borderTop">Critical Chance: <font color="#50bd27">+ 5%</font></div><strong><font color="#0066FF">Bonus damage: <font color="#50bd27">+ 2%</font></font></strong><br /><strong><font color="#0066FF">Strength: <font color="#50bd27">+ 3</font></font></strong><br /><div class="borderBottom borderTop">Value: 100 gold<br />Item level: 4<br /><font color="#CC6633">A test blade.</font></div>"`;

exports[`render snapshots (fixed game state) > itemTooltipTest (fixed weapon + shield) 2`] = `"<font color="#FFFFFF"><strong>Test Shield</strong></font><br /><div class="borderBottom borderTop">Defense: <font color="#50bd27">+ 12</font> </div><div class="borderBottom borderTop">Chance to Block: 8% </div>Damage reduction: 2.34%<br /><strong><font color="#0066FF">Endurance: <font color="#50bd27">+ 2</font></font></strong><br /><div class="borderBottom borderTop">Value: 50 gold<br />Item level: 3<br /><font color="#CC6633">A test wall.</font></div>"`;

exports[`render snapshots (fixed game state) > primaryStatUpdate 1`] = `"<div class="row"><div class="col-xs-12 primaryStatsMargin border darkBackground"><div class="row"><div class="col-xs-6"><span data-toggle="tooltip" data-placement="top" title="Damage dealt."><img src="images/stat/damage.png"></span><br />Dmg</div><div class="col-xs-6 rightAlign primaryNumberMargin"><span id="damage"></span> </div></div></div><div class="col-xs-12 primaryStatsMargin border darkBackground"><div class="row"><div class="col-xs-6"><span data-toggle="tooltip" data-placement="top" title="Spell power"><img src="images/stat/spellPower.png"></span><br />Spell Power</div><div class="col-xs-6 rightAlign primaryNumberMargin"><span id="spellPower"></span> </div></div></div><div class="col-xs-12 primaryStatsMargin border darkBackground"><div class="row"><div class="col-xs-6"><span data-toggle="tooltip" data-placement="top" title="Your mana."><img src="images/stat/mana.png"></span><br />MP</div><div class="col-xs-6 rightAlign primaryNumberMargin"><span id="mana"></span> </div></div></div><div class="col-xs-6 primaryStatsMargin border darkBackground"><div class="row"><div class="col-xs-4"><span data-toggle="tooltip" data-placement="top" title="Increase damage, inventory capacity."><img src="images/stat/strength.png"></span><br />Str</div><div class="col-xs-8 rightAlign primaryNumberMargin darkBackground"><span id="totalStrength"></span><span id="Strength" style="cursor:pointer" onclick="upgradeStrength(event);" data-toggle="tooltip" data-placement="top" title="Increase strength"><span class="glyphicon glyphicon-plus unselectable"></span></span> </div></div></div><div class="col-xs-6 primaryStatsMargin border darkBackground"><div class="row"><div class="col-xs-4"><span data-toggle="tooltip" data-placement="top" title="Increase health, health regen."><img src="images/stat/endurance.png"></span><br />End</div><div class="col-xs-8 rightAlign primaryNumberMargin darkBackground"><span id="totalEndurance"></span><span id="Endurance" style="cursor:pointer" onclick="upgradeEndurance(event);" data-toggle="tooltip" data-placement="top" title="Increase endurance"><span class="glyphicon glyphicon-plus unselectable"></span></span> </div></div></div><div class="col-xs-6 primaryStatsMargin border darkBackground"><div class="row"><div class="col-xs-4"><span data-toggle="tooltip" data-placement="top" title="Increase accuracy, evasion, defense."><img src="images/stat/agility.png"></span><br />Agi</div><div class="col-xs-8 rightAlign primaryNumberMargin darkBackground"><span id="totalAgility"></span><span id="Agility" style="cursor:pointer" onclick="upgradeAgility(event);" data-toggle="tooltip" data-placement="top" title="Increase agility"><span class="glyphicon glyphicon-plus unselectable"></span></span> </div></div></div><div class="col-xs-6 primaryStatsMargin border darkBackground"><div class="row"><div class="col-xs-4"><span data-toggle="tooltip" data-placement="top" title="Increase critical chance, critical damage."><img src="images/stat/dexterity.png"></span><br />Dex</div><div class="col-xs-8 rightAlign primaryNumberMargin darkBackground"><span id="totalDexterity"></span><span id="Dexterity" style="cursor:pointer" onclick="upgradeDexterity(event);" data-toggle="tooltip" data-placement="top" title="Increase dexterity"><span class="glyphicon glyphicon-plus unselectable"></span></span> </div></div></div><div class="col-xs-6 primaryStatsMargin border darkBackground"><div class="row"><div class="col-xs-4"><span data-toggle="tooltip" data-placement="top" title="Increase mana, mana regen, weapon skill damage"><img src="images/stat/wisdom.png"></span><br />Wis</div><div class="col-xs-8 rightAlign primaryNumberMargin darkBackground"><span id="totalWisdom"></span><span id="Wisdom" style="cursor:pointer" onclick="upgradeWisdom(event);" data-toggle="tooltip" data-placement="top" title="Increase wisdom"><span class="glyphicon glyphicon-plus unselectable"></span></span> </div></div></div><div class="col-xs-6 primaryStatsMargin border darkBackground"><div class="row"><div class="col-xs-4"><span data-toggle="tooltip" data-placement="top" title="Increase mana, weapon skill damage."><img src="images/stat/intelligence.png"></span><br />Int</div><div class="col-xs-8 rightAlign primaryNumberMargin darkBackground"><span id="totalIntelligence"></span><span id="Intelligence" style="cursor:pointer" onclick="upgradeIntelligence(event);" data-toggle="tooltip" data-placement="top" title="Increase intelligence"><span class="glyphicon glyphicon-plus unselectable"></span></span> </div></div></div><div class="col-xs-6 primaryStatsMargin border darkBackground"><div class="row"><div class="col-xs-4"><span data-toggle="tooltip" data-placement="top" title="Increase magic find, critical chance, evasion."><img src="images/stat/luck.png"></span><br />Luk</div><div class="col-xs-8 rightAlign primaryNumberMargin darkBackground"><span id="totalLuck"></span><span id="Luck" style="cursor:pointer" onclick="upgradeLuck(event);" data-toggle="tooltip" data-placement="top" title="Increase luck"><span class="glyphicon glyphicon-plus unselectable"></span></span> </div></div></div><div class="col-xs-6 primaryStatsMargin border darkBackground"><div class="row"><div class="col-xs-4"><span data-toggle="tooltip" data-placement="top" title="Your total Stat points."><img src="images/stat/Stats.png"></span><br />Stats</div><div class="col-xs-8 rightAlign primaryNumberMargin darkBackground"><span id="stats"></span> </div></div></div></div>"`;

exports[`render snapshots (fixed game state) > saveGameSlot 1`] = `"<button type="button" class="btn btn-sm btn-default"onclick="saveGameFunction('manualSave', 0)">save</button><button type="button" class="btn btn-sm btn-default"onclick="load(0)">load</button><button type="button" class="btn btn-sm btn-default" onclick="resetCheck()">reset</button><br /><br />"`;

exports[`render snapshots (fixed game state) > secondaryStatUpdate 1`] = `"<div class="row"><div class="centerText"><h4>Secondary Stats</h4></div><div class="col-xs-6 primaryStatsMargin border background" style="height:40px;"><div class="row"><div class="col-xs-8 secondaryStatMargin"><span data-toggle="tooltip" data-placement="right" title="Health gain per second.">Hp /s:</span></div><div class="col-xs-4 rightAlign secondaryStatMargin"><span data-toggle="tooltip" data-placement="right" title="Health gain per second.">2</span></div></div></div><div class="col-xs-6 primaryStatsMargin border background" style="height:40px;"><div class="row"><div class="col-xs-8 secondaryStatMargin"><span data-toggle="tooltip" data-placement="right" title="Mana gain per second.">Mp /s:</span></div><div class="col-xs-4 rightAlign secondaryStatMargin"><span data-toggle="tooltip" data-placement="right" title="Mana gain per second.">1</span></div></div></div><div class="col-xs-6 primaryStatsMargin border darkBackground" style="height:40px;"><div class="row"><div class="col-xs-8 secondaryStatMargin"><span data-toggle="tooltip" data-placement="right" title="Damage reduction:0.10%">Def:</span></div><div class="col-xs-4 rightAlign secondaryStatMargin"><span data-toggle="tooltip" data-placement="right" title="Damage reduction:0.10%">1</span></div></div></div><div class="col-xs-6 primaryStatsMargin border darkBackground" style="height:40px;"><div class="row"><div class="col-xs-8 secondaryStatMargin"><span data-toggle="tooltip" data-placement="right" title="Your chance to hit enemy.">Acc:</span></div><div class="col-xs-4 rightAlign secondaryStatMargin"><span data-toggle="tooltip" data-placement="right" title="Your chance to hit enemy.">90%</span></div></div></div><div class="col-xs-6 primaryStatsMargin border background" style="height:40px;"><div class="row"><div class="col-xs-8 secondaryStatMargin"><span data-toggle="tooltip" data-placement="right" title="Your chance to evade enemy attack.">Eva:</span></div><div class="col-xs-4 rightAlign secondaryStatMargin"><span data-toggle="tooltip" data-placement="right" title="Your chance to evade enemy attack.">5%</span></div></div></div><div class="col-xs-6 primaryStatsMargin border background" style="height:40px;"><div class="row"><div class="col-xs-8 secondaryStatMargin"><span data-toggle="tooltip" data-placement="right" title="Your amount of health gained each turn.">Life /hit:</span></div><div class="col-xs-4 rightAlign secondaryStatMargin"><span data-toggle="tooltip" data-placement="right" title="Your amount of health gained each turn.">0</span></div></div></div><div class="col-xs-6 primaryStatsMargin border darkBackground" style="height:40px;"><div class="row"><div class="col-xs-8 secondaryStatMargin"><span data-toggle="tooltip" data-placement="right" title="Chance to counter enemy attacks.">Counter %:</span></div><div class="col-xs-4 rightAlign secondaryStatMargin"><span data-toggle="tooltip" data-placement="right" title="Chance to counter enemy attacks.">0%</span></div></div></div><div class="col-xs-6 primaryStatsMargin border darkBackground" style="height:40px;"><div class="row"><div class="col-xs-8 secondaryStatMargin"><span data-toggle="tooltip" data-placement="right" title="Amount of damage dealt by a successful counter.">Damage:</span></div><div class="col-xs-4 rightAlign secondaryStatMargin"><span data-toggle="tooltip" data-placement="right" title="Amount of damage dealt by a successful counter.">0</span></div></div></div><div class="col-xs-6 primaryStatsMargin border background" style="height:40px;"><div class="row"><div class="col-xs-8 secondaryStatMargin"><span data-toggle="tooltip" data-placement="right" title="Chance to block incoming attacks.">Block %:</span></div><div class="col-xs-4 rightAlign secondaryStatMargin"><span data-toggle="tooltip" data-placement="right" title="Chance to block incoming attacks.">0%</span></div></div></div><div class="col-xs-6 primaryStatsMargin border background" style="height:40px;"><div class="row"><div class="col-xs-8 secondaryStatMargin"><span data-toggle="tooltip" data-placement="right" title="Amount of reduced damage when block is successful.">Amount:</span></div><div class="col-xs-4 rightAlign secondaryStatMargin"><span data-toggle="tooltip" data-placement="right" title="Amount of reduced damage when block is successful.">0</span></div></div></div><div class="col-xs-6 primaryStatsMargin border darkBackground" style="height:40px;"><div class="row"><div class="col-xs-8 secondaryStatMargin"><span data-toggle="tooltip" data-placement="right" title="Chance for critical strike, dealing more damage.">Crit %:</span></div><div class="col-xs-4 rightAlign secondaryStatMargin"><span data-toggle="tooltip" data-placement="right" title="Chance for critical strike, dealing more damage.">10%</span></div></div></div><div class="col-xs-6 primaryStatsMargin border darkBackground" style="height:40px;"><div class="row"><div class="col-xs-8 secondaryStatMargin"><span data-toggle="tooltip" data-placement="right" title="Critical strike multiplier">Multiplier:</span></div><div class="col-xs-4 rightAlign secondaryStatMargin"><span data-toggle="tooltip" data-placement="right" title="Critical strike multiplier">113%</span></div></div></div><div class="col-xs-6 primaryStatsMargin border background" style="height:40px;"><div class="row"><div class="col-xs-8 secondaryStatMargin"><span data-toggle="tooltip" data-placement="right" title="Increase chance to find an item after defeating enemy.">Drop %:</span></div><div class="col-xs-4 rightAlign secondaryStatMargin"><span data-toggle="tooltip" data-placement="right" title="Increase chance to find an item after defeating enemy.">101%</span></div></div></div><div class="col-xs-6 primaryStatsMargin border background" style="height:40px;"><div class="row"><div class="col-xs-8 secondaryStatMargin"><span data-toggle="tooltip" data-placement="right" title="More gold per enemy defeat.">Gold %:</span></div><div class="col-xs-4 rightAlign secondaryStatMargin"><span data-toggle="tooltip" data-placement="right" title="More gold per enemy defeat.">100%</span></div></div></div><div class="col-xs-6 primaryStatsMargin border darkBackground" style="height:40px;"><div class="row"><div class="col-xs-8 secondaryStatMargin"><span data-toggle="tooltip" data-placement="right" title="More experience for each enemy defeated.">Exp %:</span></div><div class="col-xs-4 rightAlign secondaryStatMargin"><span data-toggle="tooltip" data-placement="right" title="More experience for each enemy defeated.">100%</span></div></div></div></div>"`;

exports[`render snapshots (fixed game state) > shopOther 1`] = `"<div class="row"><div class="col-xs-12"><div class="row"><div class="col-xs-12"><div class="c3"><img src=images/stat.png alt="Buy"><br />Stat Points - 500 Gold<br /><button type="button" class="buy" onclick="buyStat(1)">Buy</button><button type="button" class="buy" onclick="buyStat(10)">Buy 10</button><button type="button" class="buy" onclick="buyStat(100)">Buy 100</button></div></div><div class="col-xs-12"><div class="c3"><img src=images/bag.png alt="Buy"><br />Backpack - 100 Gold<br /><button type="button" class="buy" onclick="buyBackpack(1)">Buy</button><button type="button" class="buy" onclick="buyBackpack(10)">Buy 10</button><button type="button" class="buy" onclick="buyBackpack(100)">Buy 100</button></div></div><div class="col-xs-12"><div class="c3"><img src=images/smallPotion.png alt="Buy"><br />Small Potion - 20 Gold<br /><button type="button" class="buy" onclick="buySmallPotion(1)">Buy</button><button type="button" class="buy" onclick="buySmallPotion(10)">Buy 10</button><button type="button" class="buy" onclick="buySmallPotion(100)">Buy 100</button></div></div><div class="col-xs-12"><div class="c3"><img src=images/mediumPotion.png alt="Buy"><br />Medium Potion - 100 Gold<br /><button type="button" class="buy" onclick="buyMediumPotion(1)">Buy</button><button type="button" class="buy" onclick="buyMediumPotion(10)">Buy 10</button><button type="button" class="buy" onclick="buyMediumPotion(100)">Buy 100</button></div></div><div class="col-xs-12"><div class="c3"><img src=images/superPotion.png alt="Buy"><br />Super Potion - 500 Gold<br /><button type="button" class="buy" onclick="buySuperPotion(1)">Buy</button><button type="button" class="buy" onclick="buySuperPotion(10)">Buy 10</button><button type="button" class="buy" onclick="buySuperPotion(100)">Buy 100</button></div></div></div></div></div>"`;

exports[`render snapshots (fixed game state) > startingScreen 1`] = `"<div class="row"><div class="col-xs-6 col-xs-3"><div class="btn-group-vertical" role="group" aria-label="New game, load game"><button type="button" style="margin-bottom:5px;" class="btn btn-default border" onclick="newGameSlot();">New Game</button><button type="button" style="margin-bottom:5px;" class="btn btn-default border" onclick="loadGameSlot();">Load</button><button type="button" style="margin-bottom:5px;" class="btn btn-default border" onclick="resetallSavesCheck();">Reset all saves</button><label><input type="checkbox" id="hardcoreMode" style ="visibility:visible; position:relative;" onclick="hardcoreModeCheck();">Hardcore Mode?</label></div><button type="button" class="btn btn-default shopButton" title="Mute music" onclick="muteAudio();changeMusicImage();"><span id="musicImage" class="glyphicon glyphicon-volume-up" aria-hidden="true"></span></button></div></div><div class="row" style="position:relative; left:-30%;"><div class="col-xs-8 col-xs-offset-2"><h4>If you are unable to start a game, use the button above to reset all saves. If you are seeing this message for the first time after an update, resetting your save is recommended.</h4></div></div>"`;
