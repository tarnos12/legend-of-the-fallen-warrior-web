exports[`render snapshots (fixed game state) > CreateWeaponSkillHtml 1`] = `"<div class="row"><div class="col-xs-10 col-xs-offset-1"><div class="row"><div class="col-xs-2 passiveMargin"><a class="tooltips"><img class="skillBorder" src="images/skills/sword.png"><span style="width:300px; bottom:30px; right:-150px;"><div class="row"><div class="col-xs-12">Sword skill progress:<br />Level: 1<br /><div class="progress"><div style="width: 0%;" aria-valuemax="100" aria-valuemin="0" aria-valuenow="60" role="progressbar" class="progress-bar" id="sword1"><span id="sword">0%</span></div></div></div></div>Stat Multiplier:<br />Strength: 102%<br />Agility: 102%<br /></span></a></div><div class="col-xs-2 passiveMargin"><a class="tooltips"><img class="skillBorder" src="images/skills/axe.png"><span style="width:300px; bottom:30px; right:-150px;"><div class="row"><div class="col-xs-12">Axe skill progress:<br />Level: 1<br /><div class="progress"><div style="width: 0%;" aria-valuemax="100" aria-valuemin="0" aria-valuenow="60" role="progressbar" class="progress-bar" id="axe1"><span id="axe">0%</span></div></div></div></div>Stat Multiplier:<br />Strength: 102%<br />Endurance: 102%<br /></span></a></div><div class="col-xs-2 passiveMargin"><a class="tooltips"><img class="skillBorder" src="images/skills/mace.png"><span style="width:300px; bottom:30px; right:-150px;"><div class="row"><div class="col-xs-12">Mace skill progress:<br />Level: 1<br /><div class="progress"><div style="width: 0%;" aria-valuemax="100" aria-valuemin="0" aria-valuenow="60" role="progressbar" class="progress-bar" id="mace1"><span id="mace">0%</span></div></div></div></div>Stat Multiplier:<br />Endurance: 102%<br />Wisdom: 102%<br /></span></a></div><div class="col-xs-2 passiveMargin"><a class="tooltips"><img class="skillBorder" src="images/skills/staff.png"><span style="width:300px; bottom:30px; right:-150px;"><div class="row"><div class="col-xs-12">Staff skill progress:<br />Level: 1<br /><div class="progress"><div style="width: 0%;" aria-valuemax="100" aria-valuemin="0" aria-valuenow="60" role="progressbar" class="progress-bar" id="staff1"><span id="staff">0%</span></div></div></div></div>Stat Multiplier:<br />Intelligence: 102%<br />Wisdom: 102%<br /></span></a></div><div class="col-xs-2 passiveMargin"><a class="tooltips"><img class="skillBorder" src="images/skills/ranged.png"><span style="width:300px; bottom:30px; right:-150px;"><div class="row"><div class="col-xs-12">Ranged skill progress:<br />Level: 1<br /><div class="progress"><div style="width: 0%;" aria-valuemax="100" aria-valuemin="0" aria-valuenow="60" role="progressbar" class="progress-bar" id="ranged1"><span id="ranged">0%</span></div></div></div></div>Stat Multiplier:<br />Strength: 102%<br />Dexterity: 102%<br /></span></a></div></div><div class="row"><div class="col-xs-2"><div class="row"><div class="col-xs-12 passiveMargin"><a class="tooltips"><img class="skillBorder" src="images/skills/SavageStrike.png"><span style="width:200px; bottom:30px; right:-100px;">Savage Strike<br />Weapon skill required: 1<br />Damage: 17(Strength/Agility based).<br />Life steal: 1 each time you attack.</span></a><div class="row"><div class="col-xs-8 col-xs-offset-2"><img class="skillBorder" src="images/arrow.png"></div></div></div><div class="col-xs-12 passiveMargin"><a class="tooltips"><img class="skillBorder" src="images/skills/SwordFinesse.png"><span style="width:200px; bottom:30px; right:-100px;">Sword Finesse<br />Weapon skill required: 5<br />Damage increase:1<br />20% total agility added to your min and max damage.</span></a><div class="row"><div class="col-xs-8 col-xs-offset-2"><img class="skillBorder" src="images/arrow.png"></div></div></div><div class="col-xs-12 passiveMargin"><a class="tooltips"><img class="skillBorder" src="images/skills/ParryAndRiposte.png"><span style="width:200px; bottom:30px; right:-100px;">Parry and Riposte<br />Weapon skill required: 10<br />Block chance: 10% of 4 damage.<br />Counter chance: 1% f