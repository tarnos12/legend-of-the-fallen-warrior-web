exports[`render snapshots (fixed game state) > CreateMonsterHtml 1`] = `"<div class="row" style="padding:4px 0;"><div class="col-xs-12 c3"><h4>Varik's Hideout</h4></div><div class="col-xs-12" style="font-weight:bold;">Wave 1: Varik Grunt — Killed: 0</div><div class="col-xs-12" style="opacity:0.75;">Wave 2: 🔒 unlocks at 10 Varik Grunt kills (0/10)</div><div class="col-xs-12" style="opacity:0.4;">Wave 3: ???</div><div class="col-xs-12" style="opacity:0.4;">Wave 4: ???</div><div class="col-xs-12" style="opacity:0.4;">Wave 5: ???</div><div class="col-xs-12" style="opacity:0.4;">Wave 6: ???</div><div class="col-xs-12" style="opacity:0.4;">Wave 7: ???</div><div class="col-xs-12" style="opacity:0.4;">Wave 8: ???</div></div>"`;

