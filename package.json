{
  "name": "legend-of-the-fallen-warrior",
  "version": "1.8.0",
  "private": true,
  "description": "Legend of the Fallen Warrior - idle/incremental browser RPG",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src test",
    "format": "prettier --write \"src/**/*.js\" \"test/**/*.js\" \"*.mjs\" \"eslint.config.js\"",
    "format:check": "prettier --check \"src/**/*.js\" \"test/**/*.js\" \"*.mjs\" \"eslint.config.js\""
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.6.0",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.9.4",
    "vite": "^7.1.0",
    "vitest": "^4.1.9"
  }
}
